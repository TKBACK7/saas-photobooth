# Copie para .env.local e preencha com as chaves do seu projeto Supabase
# (Settings -> API Keys no painel do Supabase)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Painel admin (/admin) ---
# Chave service_role (Settings -> API Keys -> aba "Legacy anon, service_role"
# -> service_role -> Reveal) ou uma Secret key (sb_secret_...).
# NUNCA exponha essa chave no navegador — sem prefixo NEXT_PUBLIC!
SUPABASE_SERVICE_ROLE_KEY=

# Senha de acesso ao painel /admin (invente uma senha forte)
ADMIN_PASSWORD=
