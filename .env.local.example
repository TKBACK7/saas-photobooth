# Copie este arquivo para .env.local (SÓ NO SEU COMPUTADOR — nunca suba
# o .env.local pro GitHub!) e preencha com as chaves do seu projeto Supabase
# (Settings -> API Keys no painel do Supabase)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Painel admin (/admin) ---
# Secret key (sb_secret_...) ou chave service_role legada.
# NUNCA exponha essa chave no navegador — sem prefixo NEXT_PUBLIC!
SUPABASE_SERVICE_ROLE_KEY=

# Senha de acesso ao painel /admin (invente uma senha forte)
ADMIN_PASSWORD=
